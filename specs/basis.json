{
	"datasources": [
		{
			"name": "basis",
			"schema": {
				"attributes": [
					{
						"name": "id",
						"string": {
							"computed_optional_required": "computed_optional",
							"description": "The unique identifier for the basis"
						}
					},
					{
						"name": "name",
						"string": {
							"computed_optional_required": "computed_optional",
							"description": "The unique name of the basis"
						}
					},
					{
						"name": "config",
						"single_nested": {
							"computed_optional_required": "computed",
							"attributes": [
								{
									"name": "allowed_envs",
									"list": {
										"computed_optional_required": "computed",
										"element_type": {
											"string": {}
										},
										"description": "limit the execution of basis watcher \u0026 colletor to these env, if empty then only primary env is allowed"
									}
								},
								{
									"name": "collector",
									"single_nested": {
										"computed_optional_required": "computed",
										"attributes": [
											{
												"name": "bounce_duration",
												"string": {
													"computed_optional_required": "computed",
													"description": "format time.ParseDuration e.g. 1h, 30m, in case not all values needs to be collected, for e.g."
												}
											},
											{
												"name": "max_parallel",
												"int64": {
													"computed_optional_required": "computed",
													"description": "max number of concurrent collect task to run"
												}
											},
											{
												"name": "max_size",
												"string": {
													"computed_optional_required": "computed",
													"description": "max size of collected artifact in datasize.ParseString format eg. 1kb, 500mb"
												}
											},
											{
												"name": "run_spec",
												"single_nested": {
													"computed_optional_required": "computed"
												}
											},
											{
												"name": "timeout",
												"string": {
													"computed_optional_required": "computed",
													"description": "format time.ParseDuration e.g. 1h, 30m"
												}
											}
										],
										"description": "collector config when artifact are fetched by a different process instead of watcher"
									}
								},
								{
									"name": "source",
									"single_nested": {
										"computed_optional_required": "computed",
										"attributes": [
											{
												"name": "fetch",
												"single_nested": {
													"computed_optional_required": "computed",
													"attributes": [
														{
															"name": "check_sum",
															"string": {
																"computed_optional_required": "computed"
															}
														},
														{
															"name": "headers",
															"map": {
																"computed_optional_required": "computed",
																"element_type": {
																	"string": {}
																}
															}
														},
														{
															"name": "insecure",
															"bool": {
																"computed_optional_required": "computed"
															}
														},
														{
															"name": "options",
															"map": {
																"computed_optional_required": "computed",
																"element_type": {
																	"string": {}
																}
															}
														},
														{
															"name": "uri",
															"string": {
																"computed_optional_required": "computed"
															}
														}
													]
												}
											},
											{
												"name": "format",
												"string": {
													"computed_optional_required": "computed",
													"description": "if empty then assumed json"
												}
											},
											{
												"name": "raw",
												"string": {
													"computed_optional_required": "computed",
													"description": "template string used directly"
												}
											}
										],
										"description": "( required ) source config of basis to be used by both watcher to check for new version"
									}
								},
								{
									"name": "watcher",
									"single_nested": {
										"computed_optional_required": "computed",
										"attributes": [
											{
												"name": "env",
												"map": {
													"computed_optional_required": "computed",
													"element_type": {
														"string": {}
													},
													"description": "env variable to set for the container image"
												}
											},
											{
												"name": "image",
												"string": {
													"computed_optional_required": "computed",
													"description": "container image name"
												}
											},
											{
												"name": "no_collect",
												"bool": {
													"computed_optional_required": "computed",
													"description": "if true then a separate collect job will launch to get new version. To handle cases where collection can take a lot of resources and time"
												}
											},
											{
												"name": "registry_auth",
												"map": {
													"computed_optional_required": "computed",
													"element_type": {
														"string": {}
													},
													"description": "auth for registry if image is not public"
												}
											},
											{
												"name": "run_spec",
												"single_nested": {
													"computed_optional_required": "computed",
													"description": "resource and other limits along with driver override, other than docker only podman can be used for now"
												}
											}
										],
										"description": "( required ) watcher image and other config details, for now collector uses the same image as watcher"
									}
								}
							],
							"description": "Configuration details for the basis"
						}
					},
					{
						"name": "created",
						"string": {
							"computed_optional_required": "computed",
							"description": "The timestamp when the basis was created"
						}
					},
					{
						"name": "description",
						"string": {
							"computed_optional_required": "computed",
							"description": "A description of the basis"
						}
					},
					{
						"name": "engine_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "EngineID holds the value of the \"engineID\" field."
						}
					},
					{
						"name": "env_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "EnvID holds the value of the \"envID\" field."
						}
					},
					{
						"name": "frozen",
						"bool": {
							"computed_optional_required": "computed",
							"description": "Whether the basis is frozen"
						}
					},
					{
						"name": "kind",
						"string": {
							"computed_optional_required": "computed",
							"description": "The kind of basis (e.g., git, s3, gcs, etc.)"
						}
					},
					{
						"name": "org_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "The organization ID that the basis belongs to"
						}
					},
					{
						"name": "status",
						"string": {
							"computed_optional_required": "computed",
							"description": "The current status of the basis"
						}
					},
					{
						"name": "store_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "StoreID holds the value of the \"storeID\" field."
						}
					},
					{
						"name": "updated",
						"string": {
							"computed_optional_required": "computed",
							"description": "The timestamp when the basis was last updated"
						}
					},
					{
						"name": "version",
						"int64": {
							"computed_optional_required": "computed",
							"description": "The version of the basis"
						}
					}
				]
			}
		}
	],
